trigger:
  branches:
    include:
      - main
      - master

pr:
  branches:
    include:
      - main
      - master

pool:
  vmImage: 'ubuntu-latest'

steps:
  - task: NodeTool@0
    inputs:
      versionSpec: '20.x'

  - script: npx harness-lab@latest enforce
    displayName: 'Architecture Enforcement'

  - script: npx harness-lab@latest doctor
    displayName: 'Doc Health Check'

  - script: npx harness-lab@latest garden
    displayName: 'Doc Garden (link check)'
