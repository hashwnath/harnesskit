{
  "name": "harness-lab",
  "version": "0.1.0",
  "description": "Plug-and-play SDK to set up Harness Engineering (agent-first development) in any repo, any IDE, any git provider",
  "type": "module",
  "bin": {
    "harness-lab": "./bin/cli.js"
  },
  "main": "src/index.js",
  "exports": {
    ".": "./src/index.js",
    "./enforce": "./src/enforcers/index.js"
  },
  "scripts": {
    "start": "node bin/cli.js",
    "test": "node --test tests/*.test.js",
    "lint": "echo 'No external linter — zero deps'"
  },
  "keywords": [
    "ai",
    "agents",
    "agents-md",
    "harness-engineering",
    "copilot",
    "claude-code",
    "cursor",
    "windsurf",
    "coding-agent",
    "developer-tools",
    "scaffolding",
    "sdk"
  ],
  "author": "Hashwanth Sutharapu <hsuthara@asu.edu>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": ""
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "bin/",
    "src/",
    "README.md",
    "LICENSE"
  ]
}
